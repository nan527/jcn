<!-- pages/post/post.wxml -->
<view class="post-page">

  <!-- 标题 -->
  <van-cell-group inset>
    <van-field
      label="标题"
      placeholder="请输入帖子标题"
      value="{{ title }}"
      bind:change="onTitleChange"
      maxlength="{{ 50 }}"
      show-word-limit
      required
    ></van-field>
  </van-cell-group>

  <!-- 正文 -->
  <van-cell-group inset style="margin-top: 24rpx;">
    <van-field
      type="textarea"
      placeholder="分享你和宠物的故事…"
      value="{{ content }}"
      bind:change="onContentChange"
      autosize="{{ { minHeight: 200 } }}"
      maxlength="{{ 2000 }}"
      show-word-limit
    ></van-field>
  </van-cell-group>

  <!-- 图片上传 -->
  <view class="section-card">
    <view class="section-title">
      <van-icon name="photo-o" size="32rpx" color="#FF9800"></van-icon>
      <text class="section-title__text">添加图片</text>
      <text class="section-title__hint">（最多9张）</text>
    </view>
    <van-uploader
      file-list="{{ fileList }}"
      bind:after-read="afterRead"
      bind:delete="deleteImage"
      max-count="{{ 9 }}"
      multiple
      accept="image"
    ></van-uploader>
  </view>

  <!-- 话题选择 -->
  <view class="section-card">
    <view class="section-title">
      <van-icon name="label-o" size="32rpx" color="#FF9800"></van-icon>
      <text class="section-title__text">选择话题</text>
      <text class="section-title__hint">（最多3个）</text>
    </view>
    <view class="topic-list">
      <view
        wx:for="{{ topics }}"
        wx:key="*this"
        class="topic-tag {{ selectedTopics.indexOf(item) >= 0 ? 'topic-tag--active' : '' }}"
        data-topic="{{ item }}"
        bindtap="toggleTopic"
      >
        <text>#{{ item }}</text>
      </view>
    </view>
    <!-- 已选话题 -->
    <view class="selected-topics" wx:if="{{ selectedTopics.length > 0 }}">
      <van-tag
        wx:for="{{ selectedTopics }}"
        wx:key="*this"
        type="primary"
        color="#FF9800"
        closeable
        data-topic="{{ item }}"
        bind:close="toggleTopic"
        style="margin-right: 12rpx; margin-bottom: 12rpx;"
      >#{{ item }}</van-tag>
    </view>
  </view>

  <!-- 发布按钮 -->
  <view class="publish-area">
    <van-button
      type="primary"
      block
      round
      size="large"
      loading="{{ publishing }}"
      loading-text="发布中…"
      color="linear-gradient(135deg, #FF9800, #FFB74D)"
      bindtap="publish"
    >发布帖子</van-button>
  </view>

</view>
