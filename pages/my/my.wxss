/* pages/my/my.wxss */
.my-page {
  min-height: 100vh;
  background: #f5f5f5;
}

/* ===== 顶部用户卡片 ===== */
.user-header {
  position: relative;
  height: 340rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
}

.user-header__bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.user-header__content {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  padding: 100rpx 48rpx 0;
}

.avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.user-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.8);
  background: #eee;
  display: block;
}

.avatar-edit-badge {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #FF9800;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #fff;
}

.user-meta {
  margin-left: 32rpx;
  display: flex;
  flex-direction: column;
}

.user-nickname {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.user-role-badge {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
  background: linear-gradient(135deg, #FFF3E0, #FFE0B2);
  border-radius: 24rpx;
  padding: 6rpx 20rpx;
  align-self: flex-start;
}

.role-badge-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 8rpx;
}

.role-badge-text {
  font-size: 22rpx;
  color: #E65100;
  font-weight: 600;
}

.user-login-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

/* ===== 功能入口卡片 ===== */
.func-card {
  margin: -40rpx 24rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  position: relative;
  z-index: 2;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.func-card__title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 28rpx;
}

.func-grid {
  display: flex;
  justify-content: space-around;
}

.func-grid__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 25%;
}

.func-grid__icon {
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 12rpx;
}

.func-grid__label {
  font-size: 24rpx;
  color: #666;
}

/* ===== 列表菜单中的图标 ===== */
.cell-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
  vertical-align: middle;
}

/* ===== 退出登录 ===== */
.logout-area {
  padding: 48rpx 48rpx 80rpx;
}
