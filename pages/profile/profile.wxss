/* pages/profile/profile.wxss */
.profile-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* ===== 当前头像 ===== */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 32rpx;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
}

.current-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.8);
  background: #eee;
}

.avatar-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 16rpx;
}

/* ===== 头像选择器 ===== */
.avatar-picker {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  padding: 32rpx 24rpx 16rpx;
  background: #fff;
  margin: -20rpx 24rpx 24rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  position: relative;
  z-index: 2;
}

.avatar-option {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  margin: 8rpx 16rpx;
  overflow: hidden;
  border: 4rpx solid transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f7f8fa;
}

.avatar-option--active {
  border-color: #FF9800;
  box-shadow: 0 0 0 4rpx rgba(255, 152, 0, 0.2);
}

.avatar-option__img {
  width: 100%;
  height: 100%;
}

.avatar-option--upload {
  border: 2rpx dashed #ccc;
  background: #fafafa;
}

/* ===== 保存按钮 ===== */
.save-area {
  padding: 40rpx 48rpx;
}
