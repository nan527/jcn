<!-- pages/foster/foster.wxml -->
<view class="foster-page">

  <!-- 选择宠物（从宠物档案） -->
  <view class="section-card">
    <view class="section-title">
      <van-icon name="tosend" size="32rpx" color="#FF9800"></van-icon>
      <text class="section-title__text">选择宠物</text>
      <text class="section-title__hint">（必须从宠物档案中选择）</text>
    </view>

    <view class="pet-empty-tip" wx:if="{{ myPets.length === 0 }}">
      <text class="pet-empty-tip__text">暂无宠物档案，请先添加宠物</text>
      <view class="pet-empty-tip__btn" bindtap="toPetArchive">
        <van-icon name="plus" size="24rpx" color="#FF9800"></van-icon>
        <text style="color:#FF9800;font-size:26rpx;margin-left:8rpx;">去添加</text>
      </view>
    </view>

    <view class="pet-selector" wx:if="{{ myPets.length > 0 }}">
      <view
        class="pet-opt {{ selectedPetId === item._id ? 'pet-opt--active' : '' }}"
        wx:for="{{ myPets }}"
        wx:key="_id"
        data-id="{{ item._id }}"
        bindtap="onSelectPet"
      >
        <image class="pet-opt__avatar" src="{{ item.photo || '/static/tab-pet-orange.png' }}" mode="aspectFill" />
        <view class="pet-opt__info">
          <text class="pet-opt__name">{{ item.name }}</text>
          <text class="pet-opt__detail">{{ item.species }}{{ item.age ? ' · ' + item.age + '岁' : '' }}</text>
        </view>
        <van-icon wx:if="{{ selectedPetId === item._id }}" name="success" size="40rpx" color="#FF9800"></van-icon>
      </view>
    </view>
  </view>

  <!-- 宠物照片（补充） -->
  <view class="section-card" wx:if="{{ selectedPetId }}">
    <view class="section-title">
      <van-icon name="photo-o" size="32rpx" color="#FF9800"></van-icon>
      <text class="section-title__text">补充照片</text>
      <text class="section-title__hint">（最多6张，可选）</text>
    </view>
    <van-uploader
      file-list="{{ fileList }}"
      bind:after-read="afterRead"
      bind:delete="deleteImage"
      max-count="{{ 6 }}"
      multiple
      accept="image"
    ></van-uploader>
  </view>

  <!-- 已选宠物信息（只读展示） -->
  <van-cell-group inset title="宠物信息" wx:if="{{ selectedPetId }}">
    <van-cell title="宠物名称" value="{{ petName }}"></van-cell>
    <van-cell title="品种" value="{{ breed }}"></van-cell>
    <van-cell title="年龄" value="{{ age || '未填写' }}"></van-cell>
    <van-cell title="性格" value="{{ character || '未填写' }}"></van-cell>
    <van-field label="特殊需求" type="textarea" placeholder="如：需要喂药、不能吃鸡肉" value="{{ specialNeeds }}" bind:change="onSpecialNeedsChange" autosize="{{ { minHeight: 80 } }}"></van-field>
  </van-cell-group>

  <!-- 寄养信息 -->
  <van-cell-group inset title="寄养信息" style="margin-top: 24rpx;">
    <picker mode="date" value="{{ startDate }}" start="{{ today }}" bindchange="onStartDateChange">
      <van-cell title="寄养开始" value="{{ startDate || '请选择日期' }}" is-link required></van-cell>
    </picker>
    <picker mode="date" value="{{ endDate }}" start="{{ startDate || today }}" bindchange="onEndDateChange">
      <van-cell title="寄养结束" value="{{ endDate || '请选择日期' }}" is-link required></van-cell>
    </picker>
    <van-cell title="寄养天数" value="{{ days ? days + '天' : '选择日期后自动计算' }}"></van-cell>
    <van-field label="预算价格" placeholder="如：50元/天" value="{{ budget }}" bind:change="onBudgetChange"></van-field>
    <van-field label="寄养说明" type="textarea" placeholder="请详细描述寄养需求和注意事项" value="{{ description }}" bind:change="onDescriptionChange" required autosize="{{ { minHeight: 120 } }}"></van-field>
  </van-cell-group>

  <!-- 联系方式 -->
  <van-cell-group inset title="联系方式" style="margin-top: 24rpx;">
    <van-field label="联系人" placeholder="您的称呼" value="{{ contactName }}" bind:change="onContactNameChange" required></van-field>
    <van-field label="手机号" placeholder="方便联系的手机号" value="{{ contactPhone }}" bind:change="onContactPhoneChange" type="number" required></van-field>
    <van-field label="所在地区" placeholder="如：北京市朝阳区" value="{{ location }}" bind:change="onLocationChange"></van-field>
  </van-cell-group>

  <!-- 发布按钮 -->
  <view class="publish-area">
    <van-button
      type="primary"
      block
      round
      size="large"
      loading="{{ publishing }}"
      loading-text="发布中…"
      color="linear-gradient(135deg, #FF9800, #FFB74D)"
      bindtap="publish"
    >发布寄养信息</van-button>
  </view>

</view>
