/* ===== 登录页样式 ===== */
.container {
  min-height: 100vh;
  background: linear-gradient(160deg, #fff8f0 0%, #ffffff 40%, #fefefe 100%);
  padding: 0 56rpx;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

/* 装饰背景圆 */
.container::before {
  content: '';
  position: absolute;
  top: -200rpx;
  right: -150rpx;
  width: 500rpx;
  height: 500rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,152,0,0.06) 0%, transparent 70%);
  pointer-events: none;
}

.container::after {
  content: '';
  position: absolute;
  bottom: -100rpx;
  left: -200rpx;
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,183,77,0.05) 0%, transparent 70%);
  pointer-events: none;
}

/* Logo 区域 */
.header {
  margin-top: 120rpx;
  margin-bottom: 72rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 1;
}

.logo-wrapper {
  width: 168rpx;
  height: 168rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 40rpx rgba(255, 152, 0, 0.18);
  background: #fff;
}

.logo-img {
  width: 168rpx;
  height: 168rpx;
}

.app-name {
  font-size: 56rpx;
  font-weight: 800;
  color: #222;
  letter-spacing: 6rpx;
  background: linear-gradient(135deg, #FF9800, #F57C00);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.app-slogan {
  font-size: 24rpx;
  color: #aaa;
  margin-top: 14rpx;
  letter-spacing: 3rpx;
  font-weight: 300;
}

/* 角色选择 */
.role-section {
  margin-bottom: 48rpx;
  position: relative;
  z-index: 1;
}

.section-title {
  font-size: 26rpx;
  color: #bbb;
  margin-bottom: 28rpx;
  padding-left: 8rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
}

.role-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 28rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid #f2f2f2;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
  transition: all 0.3s ease;
}

.role-card:active {
  transform: scale(0.98);
}

.role-card--active {
  border-color: #FF9800;
  background: linear-gradient(135deg, #FFFBF5, #FFF8EE);
  box-shadow: 0 8rpx 32rpx rgba(255, 152, 0, 0.14);
  transform: translateY(-2rpx);
}

.role-card__left {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  background: #f7f8fa;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 28rpx;
  flex-shrink: 0;
  transition: all 0.3s ease;
}

.role-card--active .role-card__left {
  background: linear-gradient(135deg, #FFF3E0, #FFE0B2);
  box-shadow: 0 4rpx 12rpx rgba(255, 152, 0, 0.15);
}

.role-card__center {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.role-card__label {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.role-card--active .role-card__label {
  color: #E65100;
}

.role-card__desc {
  font-size: 23rpx;
  color: #aaa;
  line-height: 1.5;
}

.role-card--active .role-card__desc {
  color: #F57C00;
}

.role-card__right {
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* 宠主登录模式切换 */
.login-mode-tabs {
  display: flex;
  flex-direction: row !important;
  align-items: center;
  margin-bottom: 36rpx;
  position: relative;
  z-index: 1;
  background: #f5f5f5;
  border-radius: 24rpx;
  padding: 8rpx;
  width: 100%;
  box-sizing: border-box;
}

.mode-tab {
  width: 50%;
  display: flex;
  flex-direction: row !important;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #999;
  background: transparent;
  transition: all 0.3s ease;
}

.mode-tab:active {
  opacity: 0.8;
}

.mode-tab--active {
  color: #333;
  background: #fff;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.mode-tab__icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
}

.mode-tab__text {
  font-size: 28rpx;
  line-height: 80rpx;
}

/* 账号输入区 */
.account-section {
  margin-bottom: 28rpx;
  position: relative;
  z-index: 1;
  background: #fff;
  border-radius: 24rpx;
  padding: 8rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.03);
}

.register-row {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0 12rpx;
}

.register-tip {
  font-size: 24rpx;
  color: #bbb;
}

.register-link {
  font-size: 24rpx;
  color: #FF9800;
  margin-left: 8rpx;
  font-weight: 600;
}

.register-form-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
  padding: 24rpx 32rpx 0;
}

.register-actions {
  display: flex;
  margin-top: 24rpx;
  padding: 0 32rpx 24rpx;
}

/* 底部按钮 */
.footer-btn {
  margin-top: auto;
  padding-bottom: 80rpx;
  position: relative;
  z-index: 1;
}

.login-btn-wrap {
  border-radius: 48rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 40rpx rgba(255, 152, 0, 0.3);
}

.agreement {
  margin-top: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.agreement__text {
  font-size: 24rpx;
  color: #bbb;
}

.agreement__link {
  font-size: 24rpx;
  color: #FF9800;
  margin-left: 4rpx;
  font-weight: 500;
}
