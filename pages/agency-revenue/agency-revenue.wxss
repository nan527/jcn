/* pages/agency-revenue/agency-revenue.wxss */
.revenue-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* ===== 顶部汇总卡 ===== */
.summary-header {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  padding: 40rpx 32rpx 32rpx;
}

.summary-main {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.summary-main__label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

.summary-main__num {
  font-size: 60rpx;
  font-weight: 800;
  color: #fff;
  margin-top: 8rpx;
  letter-spacing: 2rpx;
}

.summary-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: rgba(255,255,255,0.2);
  border-radius: 20rpx;
  padding: 24rpx 0;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.summary-item__num {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

.summary-item__label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 4rpx;
}

.summary-divider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(255,255,255,0.3);
}

/* ===== 图表卡片通用 ===== */
.chart-card {
  margin: 20rpx 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.chart-card__title {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 24rpx;
}

.chart-card__text {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

/* ===== 月度柱状图 (横向) ===== */
.bar-chart {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.bar-chart__row {
  display: flex;
  align-items: center;
}

.bar-chart__label {
  width: 80rpx;
  font-size: 24rpx;
  color: #666;
  flex-shrink: 0;
}

.bar-chart__track {
  flex: 1;
  height: 28rpx;
  background: #f5f5f5;
  border-radius: 14rpx;
  overflow: hidden;
}

.bar-chart__fill {
  height: 100%;
  background: linear-gradient(90deg, #FF9800, #FFB74D);
  border-radius: 14rpx;
  transition: width 0.6s ease;
  min-width: 4rpx;
}

.bar-chart__val {
  width: 110rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #FF9800;
  text-align: right;
  flex-shrink: 0;
}

/* ===== 环形图 ===== */
.donut-section {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.donut-wrap {
  position: relative;
  width: 180px;
  height: 180px;
  flex-shrink: 0;
}

.donut-canvas {
  width: 180px;
  height: 180px;
}

.donut-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.donut-center__num {
  font-size: 36rpx;
  font-weight: 800;
  color: #333;
}

.donut-center__label {
  font-size: 20rpx;
  color: #999;
}

.donut-legend {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.legend-label {
  font-size: 24rpx;
  color: #666;
  flex: 1;
}

.legend-count {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
}

/* ===== 服务类型柱状图 ===== */
.cat-chart {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.cat-chart__row {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.cat-chart__head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.cat-chart__label {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
}

.cat-chart__amount {
  font-size: 26rpx;
  font-weight: 700;
  color: #FF9800;
}

.cat-chart__track {
  height: 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  overflow: hidden;
}

.cat-chart__fill {
  height: 100%;
  border-radius: 12rpx;
  transition: width 0.6s ease;
  min-width: 4rpx;
}

.cat-chart__ratio {
  font-size: 22rpx;
  color: #999;
  text-align: right;
}

.empty-chart {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}

.empty-chart__text {
  font-size: 26rpx;
  color: #ccc;
}

/* ===== 近7天竖向柱状图 ===== */
.daily-chart {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  height: 300rpx;
  padding-top: 20rpx;
}

.daily-chart__col {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  height: 100%;
}

.daily-chart__val {
  font-size: 22rpx;
  font-weight: 600;
  color: #FF9800;
  margin-bottom: 8rpx;
}

.daily-chart__bar-wrap {
  flex: 1;
  width: 36rpx;
  background: #f5f5f5;
  border-radius: 18rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  overflow: hidden;
}

.daily-chart__bar {
  width: 100%;
  background: linear-gradient(180deg, #FF9800, #FFB74D);
  border-radius: 18rpx;
  transition: height 0.6s ease;
  min-height: 6rpx;
}

.daily-chart__label {
  font-size: 20rpx;
  color: #999;
  margin-top: 8rpx;
}
