/* pages/foster-center/foster-center.wxss */
.fc-page {
  min-height: 100vh;
  background: #f5f5f5;
}

.tab-body {
  padding: 20rpx 24rpx 40rpx;
  min-height: 60vh;
}

/* ===== 空状态 ===== */
.empty-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #bbb;
  margin-top: 20rpx;
}

.empty-btn {
  display: flex;
  align-items: center;
  margin-top: 32rpx;
  padding: 12rpx 40rpx;
  border: 2rpx solid #FF9800;
  border-radius: 40rpx;
}

.empty-btn-text {
  font-size: 26rpx;
  color: #FF9800;
  margin-left: 8rpx;
  font-weight: 600;
}

/* ===== 通用信息卡片 (我的发布 & 我参与的) ===== */
.card-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.info-card {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.info-card__img {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
  background: #f5f5f5;
  border-radius: 16rpx;
  margin: 16rpx 0 16rpx 16rpx;
}

.info-card__body {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.info-card__top {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.info-card__name {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 240rpx;
}

.info-card__breed {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.info-card__bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.info-card__loc {
  display: flex;
  align-items: center;
  max-width: 60%;
}

.info-card__loc-text {
  font-size: 22rpx;
  color: #bbb;
  margin-left: 4rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.info-card__from {
  font-size: 22rpx;
  color: #999;
}

.info-card__status {
  flex-shrink: 0;
}

.info-card__time {
  font-size: 22rpx;
  color: #ccc;
  margin-top: 8rpx;
}

/* ===== 机构订单卡片 ===== */
.order-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
  margin-bottom: 20rpx;
}

.order-card__header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.order-card__agency {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
}

.order-card__body {
  display: flex;
  padding: 20rpx 24rpx;
}

.order-card__img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #eee;
}

.order-card__info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.order-card__name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.order-card__pet {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.order-card__price-row {
  display: flex;
  align-items: baseline;
  margin-top: 8rpx;
}

.order-card__price {
  font-size: 34rpx;
  font-weight: 800;
  color: #FF9800;
}

.order-card__unit {
  font-size: 22rpx;
  color: #999;
  margin-left: 6rpx;
}

.order-card__date {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 8rpx;
}
