<!-- pages/pet/pet.wxml -->
<view class="container">

  <!-- 加载中 -->
  <van-loading wx:if="{{ loading }}" vertical style="padding: 100rpx 0; text-align: center;">
    加载中...
  </van-loading>

  <!-- 宠物列表 -->
  <view wx:if="{{ !loading }}">

    <!-- 空状态 -->
    <view wx:if="{{ petList.length === 0 }}" class="empty-state">
      <image class="empty-icon" src="/static/tab-pet.png" mode="aspectFit" />
      <text class="empty-text">还没有宠物档案</text>
      <text class="empty-hint">点击下方按钮添加您的爱宠</text>
    </view>

    <!-- 宠物卡片列表 -->
    <view wx:for="{{ petList }}" wx:key="_id" class="pet-card">
      <view class="pet-card__avatar">
        <van-image
          wx:if="{{ item.photo }}"
          width="120rpx"
          height="120rpx"
          round
          fit="cover"
          src="{{ item.photo }}"
        />
        <van-icon wx:else name="tosend" size="60rpx" color="#FF9800" />
      </view>
      <view class="pet-card__info">
        <view class="pet-card__name-row">
          <text class="pet-card__name">{{ item.name }}</text>
          <van-tag wx:if="{{ item.petStatus === 'agency_foster' }}" type="warning" size="medium">寄养中</van-tag>
          <van-tag wx:if="{{ item.petStatus === 'pending_adopt' }}" color="#E8F5E9" text-color="#2E7D32" size="medium">待领养</van-tag>
          <van-tag wx:if="{{ item.petStatus === 'pending_foster' }}" color="#FFF3E0" text-color="#E65100" size="medium">待寄养</van-tag>
          <van-tag wx:if="{{ item.petStatus === 'waiting_pickup' }}" color="#FFF8E1" text-color="#EF6C00" size="medium">待取回</van-tag>
          <van-tag wx:if="{{ item.petStatus === 'other_foster' }}" color="#E3F2FD" text-color="#1565C0" size="medium">他人寄养</van-tag>
          <van-tag wx:if="{{ item.petStatus === 'adopted_in' }}" type="success" size="medium">领养入</van-tag>
          <van-tag wx:if="{{ item.petStatus === 'adopted_out' }}" color="#FCE4EC" text-color="#C2185B" size="medium">已送养</van-tag>
        </view>
        <text class="pet-card__detail">{{ item.species }}{{ item.age ? ' · ' + item.age + '岁' : '' }}</text>
        <text wx:if="{{ item.character }}" class="pet-card__char">{{ item.character }}</text>
      </view>
      <view class="pet-card__action">
        <van-icon
          name="edit"
          size="40rpx"
          color="#FF9800"
          data-id="{{ item._id }}"
          bindtap="editPet"
          custom-style="margin-right: 24rpx;"
        ></van-icon>
        <van-icon
          name="delete-o"
          size="40rpx"
          color="#ee0a24"
          data-id="{{ item._id }}"
          data-name="{{ item.name }}"
          bindtap="deletePet"
        ></van-icon>
      </view>
    </view>

    <!-- 添加 / 取消按钮 -->
    <view class="add-btn-area">
      <van-button
        wx:if="{{ !editingId }}"
        round
        block
        type="{{ showForm ? 'default' : 'primary' }}"
        icon="{{ showForm ? 'cross' : 'plus' }}"
        color="{{ showForm ? '' : 'linear-gradient(135deg, #FF9800, #FFB74D)' }}"
        bindtap="toggleForm"
      >{{ showForm ? '收起' : '添加宠物' }}</van-button>
      <van-button
        wx:if="{{ editingId }}"
        round
        block
        plain
        type="default"
        icon="cross"
        bindtap="cancelEdit"
      >取消编辑</van-button>
    </view>

    <!-- 添加表单（折叠） -->
    <view wx:if="{{ showForm }}" class="form-section">
      <van-cell-group title="{{ editingId ? '编辑宠物信息' : '填写宠物信息' }}">
        <van-field
          label="宠物昵称"
          placeholder="请输入宠物姓名"
          value="{{ name }}"
          bind:change="onNameChange"
          required
        />
        <van-field
          label="品种"
          placeholder="如：布偶猫、金毛"
          value="{{ species }}"
          bind:change="onSpeciesChange"
          required
        />
        <van-field
          label="年龄"
          placeholder="请输入年龄"
          value="{{ age }}"
          type="digit"
          bind:change="onAgeChange"
        />
        <van-field
          label="性格描述"
          placeholder="如：活泼、粘人"
          value="{{ character }}"
          bind:change="onCharacterChange"
        />
        <van-field
          label="特殊需求"
          placeholder="如：需要喂药、不能吃鸡肉"
          value="{{ special }}"
          bind:change="onSpecialChange"
        />
      </van-cell-group>

      <view class="upload-section">
        <text class="upload-label">上传宠物照片</text>
        <view class="upload-row">
          <van-uploader file-list="{{ fileList }}" bind:after-read="afterRead" max-count="1" />
          <view class="preset-btn" bindtap="openAvatarPicker">
            <van-icon name="photo-o" size="40rpx" color="#FF9800"></van-icon>
            <text class="preset-btn__text">预设头像</text>
          </view>
        </view>
      </view>

      <!-- 预设头像弹层 -->
      <van-popup show="{{ showAvatarPicker }}" position="bottom" round bind:close="closeAvatarPicker" custom-style="max-height:70vh;">
        <view style="padding:32rpx 24rpx 48rpx;">
          <view style="display:flex;flex-direction:row;align-items:center;justify-content:space-between;margin-bottom:24rpx;padding:0 8rpx;">
            <text style="font-size:32rpx;font-weight:700;color:#333;">选择预设头像</text>
            <van-icon name="cross" size="36rpx" color="#999" bindtap="closeAvatarPicker" />
          </view>
          <view style="display:flex;flex-direction:row;flex-wrap:wrap;">
            <view
              wx:for="{{ presetAvatars }}"
              wx:key="name"
              style="display:flex;flex-direction:column;align-items:center;width:20%;padding:10rpx 0 8rpx;box-sizing:border-box;border-radius:16rpx;background:{{ selectedPresetIdx === index ? '#FFF3E0' : 'transparent' }};{{ selectedPresetIdx === index ? 'border:2rpx solid #FF9800;' : '' }}"
              data-idx="{{ index }}"
              bindtap="onPickAvatar"
            >
              <image src="{{ item.src }}" mode="aspectFill" style="width:80rpx;height:80rpx;border-radius:50%;background:#f7f8fa;{{ selectedPresetIdx === index ? 'box-shadow:0 0 0 3rpx #FF9800;' : '' }}" />
              <text style="font-size:18rpx;color:{{ selectedPresetIdx === index ? '#E65100' : '#666' }};margin-top:6rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:110rpx;">{{ item.name }}</text>
            </view>
          </view>
        </view>
      </van-popup>

      <van-button
        type="primary"
        block
        round
        loading="{{ saving }}"
        loading-text="保存中…"
        color="linear-gradient(135deg, #FF9800, #FFB74D)"
        bindtap="savePet"
      >{{ editingId ? '保存修改' : '保存档案' }}</van-button>
    </view>

  </view>
</view>