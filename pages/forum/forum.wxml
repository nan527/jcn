<!-- pages/forum/forum.wxml -->
<view class="forum-page">

  <!-- Tab 栏 -->
  <view class="tab-bar">
    <view class="tab-item {{ tab === 'all' ? 'tab-item--active' : '' }}" data-tab="all" bindtap="switchTab">
      <text>全部帖子</text>
    </view>
    <view class="tab-item {{ tab === 'mine' ? 'tab-item--active' : '' }}" data-tab="mine" bindtap="switchTab">
      <text>我的帖子</text>
    </view>
  </view>

  <!-- 加载中 -->
  <van-loading wx:if="{{ loading }}" vertical style="padding: 120rpx 0; text-align: center;">加载中...</van-loading>

  <!-- 帖子列表 -->
  <view wx:if="{{ !loading }}">

    <!-- 空状态 -->
    <view wx:if="{{ postList.length === 0 }}" class="empty-wrap">
      <van-icon name="comment-o" size="120rpx" color="#ddd"></van-icon>
      <text class="empty-text">{{ tab === 'mine' ? '你还没有发过帖子' : '暂无帖子，快来发布第一篇吧' }}</text>
    </view>

    <!-- 帖子卡片 -->
    <view wx:for="{{ postList }}" wx:key="_id" class="post-card" data-id="{{ item._id }}" bindtap="onPostTap">
      <!-- 作者信息 -->
      <view class="post-card__header">
        <image class="post-card__avatar" src="{{ item.authorAvatar || '/static/missing-face.png' }}" mode="aspectFill"></image>
        <text class="post-card__author">{{ item.authorName || '匿名用户' }}</text>
      </view>

      <!-- 标题 & 正文 -->
      <text class="post-card__title">{{ item.title }}</text>
      <text class="post-card__content">{{ item.content }}</text>

      <!-- 图片（最多展示3张） -->
      <view wx:if="{{ item.images && item.images.length > 0 }}" class="post-card__images">
        <image
          wx:for="{{ item.images }}"
          wx:for-item="img"
          wx:key="*this"
          wx:if="{{ index < 3 }}"
          class="post-card__img"
          src="{{ img }}"
          mode="aspectFill"
        ></image>
        <view wx:if="{{ item.images.length > 3 }}" class="post-card__img-more">
          <text>+{{ item.images.length - 3 }}</text>
        </view>
      </view>

      <!-- 话题标签 -->
      <view wx:if="{{ item.topics && item.topics.length > 0 }}" class="post-card__topics">
        <van-tag
          wx:for="{{ item.topics }}"
          wx:for-item="t"
          wx:key="*this"
          plain
          color="#FF9800"
          style="margin-right: 12rpx;"
        >#{{ t }}</van-tag>
      </view>

      <!-- 底部操作栏 -->
      <view class="post-card__footer">
        <view class="post-card__action" data-id="{{ item._id }}" catchtap="onLike">
          <van-icon name="good-job-o" size="32rpx" color="#999"></van-icon>
          <text class="post-card__action-text">{{ item.likeCount || 0 }}</text>
        </view>
        <view class="post-card__action">
          <van-icon name="comment-o" size="32rpx" color="#999"></van-icon>
          <text class="post-card__action-text">{{ item.commentCount || 0 }}</text>
        </view>
      </view>
    </view>

  </view>

  <!-- 悬浮发帖按钮 -->
  <view class="fab-btn" bindtap="toCreatePost">
    <van-icon name="edit" size="44rpx" color="#fff"></van-icon>
  </view>

</view>
