/* pages/agency-reviews/agency-reviews.wxss */
.reviews-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* ===== 顶部评分概览 ===== */
.score-header {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  padding: 40rpx 32rpx 32rpx;
}

.score-main {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 28rpx;
}

.score-main__num {
  font-size: 72rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1.1;
  margin-bottom: 8rpx;
}

.score-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: rgba(255,255,255,0.2);
  border-radius: 20rpx;
  padding: 24rpx 0;
}

.score-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.score-item__num {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

.score-item__label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 4rpx;
}

.score-divider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(255,255,255,0.3);
}

/* ===== 评分分布 ===== */
.dist-card {
  margin: 20rpx 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.dist-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 20rpx;
}

.dist-row {
  display: flex;
  align-items: center;
  margin-bottom: 14rpx;
}

.dist-star {
  width: 70rpx;
  font-size: 24rpx;
  color: #666;
  flex-shrink: 0;
}

.dist-track {
  flex: 1;
  height: 22rpx;
  background: #f5f5f5;
  border-radius: 11rpx;
  overflow: hidden;
  margin: 0 16rpx;
}

.dist-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF9800, #FFB74D);
  border-radius: 11rpx;
  min-width: 4rpx;
  transition: width 0.5s ease;
}

.dist-count {
  width: 50rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
  text-align: right;
  flex-shrink: 0;
}

/* ===== 筛选区 ===== */
.filter-card {
  margin: 20rpx 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.filter-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.filter-top__title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}

.filter-reset {
  font-size: 22rpx;
  color: #E65100;
  background: #FFF3E0;
  border: 1rpx solid #FFCC80;
  border-radius: 999rpx;
  padding: 6rpx 18rpx;
}

.filter-group + .filter-group {
  margin-top: 20rpx;
}

.filter-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
  display: block;
}

.filter-scroll {
  white-space: nowrap;
}

.chip-row {
  display: inline-flex;
  gap: 12rpx;
  padding-right: 8rpx;
}

.chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #666;
  background: #f6f6f6;
  border: 1rpx solid #eee;
}

.chip--active {
  color: #E65100;
  background: #FFF3E0;
  border-color: #FFCC80;
}

/* ===== 评价列表 ===== */
.review-list-section {
  margin: 20rpx 24rpx;
}

.review-list-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.empty-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #bbb;
  margin-top: 16rpx;
}

.review-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.review-card__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.review-card__svc {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  overflow: hidden;
}

.review-card__name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.review-card__stars {
  flex-shrink: 0;
}

.review-card__body {
  margin-bottom: 16rpx;
}

.review-card__content {
  font-size: 28rpx;
  color: #444;
  line-height: 1.7;
  word-break: break-all;
}

.review-card__footer {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.review-card__pet {
  font-size: 22rpx;
  color: #999;
}

.review-card__price {
  font-size: 22rpx;
  font-weight: 600;
  color: #FF9800;
}

.review-card__time {
  font-size: 22rpx;
  color: #ccc;
  margin-left: auto;
}
