/* pages/agency/agency.wxss */
.agency-page {
  min-height: 100vh;
  background: #f5f5f5;
}

/* ===== 顶部机构卡片 ===== */
.agency-header {
  position: relative;
  height: 340rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
}

.agency-header__bg {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 0;
}

.agency-header__content {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  padding: 100rpx 48rpx 0;
}

.avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.agency-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255,255,255,0.8);
  background: #fff;
  display: block;
}

.agency-meta {
  margin-left: 32rpx;
  display: flex;
  flex-direction: column;
}

.agency-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.agency-status-badge {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
  border-radius: 24rpx;
  padding: 6rpx 20rpx;
  align-self: flex-start;
}

.badge-ok {
  background: linear-gradient(135deg, #FFF3E0, #FFE0B2);
}

.badge-pending {
  background: rgba(255,255,255,0.25);
}

.badge-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 8rpx;
}

.badge-text {
  font-size: 22rpx;
  color: #E65100;
  font-weight: 600;
}

.badge-pending .badge-text {
  color: #fff;
}

/* ===== 数据统计条 ===== */
.stats-bar {
  margin: -36rpx 24rpx 0;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  position: relative;
  z-index: 2;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stats-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #333;
}

.stats-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.stats-divider {
  width: 1rpx;
  height: 48rpx;
  background: #eee;
}

.stats-edit-icon {
  width: 44rpx;
  height: 44rpx;
}

/* ===== 运营管理 ===== */
.ops-card {
  margin: 0 24rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 16rpx 12rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
}

.ops-grid {
  display: flex;
  flex-wrap: wrap;
}

.ops-item {
  width: 33.33%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.ops-icon-wrap {
  width: 84rpx;
  height: 84rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.ops-bg-orange  { background: #FFF3E0; }
.ops-bg-blue    { background: #E3F2FD; }
.ops-bg-green   { background: #E8F5E9; }
.ops-bg-red     { background: #FFEBEE; }
.ops-bg-purple  { background: #F3E5F5; }
.ops-bg-amber   { background: #FFF8E1; }

.ops-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}

.ops-desc {
  font-size: 20rpx;
  color: #bbb;
  margin-top: 4rpx;
}

/* ===== 快捷功能 ===== */
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  padding: 36rpx 36rpx 20rpx;
}

.service-grid {
  display: flex;
  justify-content: space-around;
  background: #fff;
  margin: 0 24rpx;
  border-radius: 24rpx;
  padding: 36rpx 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
}

.service-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 25%;
}

.service-icon {
  width: 56rpx;
  height: 56rpx;
  margin-bottom: 12rpx;
}

.service-label {
  font-size: 24rpx;
  color: #666;
}

/* ===== 底部按钮 ===== */
.bottom-area {
  padding: 48rpx 48rpx 80rpx;
}
