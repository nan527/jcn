<!-- pages/foster-detail/foster-detail.wxml -->
<view class="detail-page" wx:if="{{ detail }}">

  <!-- 图片轮播 -->
  <swiper class="img-swiper" indicator-dots autoplay circular wx:if="{{ detail.images && detail.images.length > 0 }}">
    <swiper-item wx:for="{{ detail.images }}" wx:key="*this">
      <image class="swiper-img" src="{{ item }}" mode="aspectFill" data-src="{{ item }}" bindtap="previewImg" />
    </swiper-item>
  </swiper>
  <view class="img-placeholder" wx:else>
    <image src="/static/pet/logo.png" mode="aspectFit" style="width:160rpx;height:160rpx;opacity:.3;" />
  </view>

  <!-- 基本信息 -->
  <view class="info-section">
    <view class="info-row-main">
      <text class="pet-name">{{ detail.petName }}</text>
      <van-tag wx:if="{{ detail._type === 'foster' }}" type="warning" size="large">寄养</van-tag>
      <van-tag wx:if="{{ detail._type === 'adopt' }}" type="success" size="large">送养</van-tag>
    </view>
    <view class="info-row" wx:if="{{ detail.breed }}">
      <text class="info-label">品种</text>
      <text class="info-val">{{ detail.breed }}</text>
    </view>
    <view class="info-row" wx:if="{{ detail.age }}">
      <text class="info-label">年龄</text>
      <text class="info-val">{{ detail.age }}</text>
    </view>
    <view class="info-row" wx:if="{{ detail.gender && detail.gender !== 'unknown' }}">
      <text class="info-label">性别</text>
      <text class="info-val">{{ detail.gender === 'male' ? '公' : '母' }}</text>
    </view>
    <view class="info-row" wx:if="{{ detail.character }}">
      <text class="info-label">性格</text>
      <text class="info-val">{{ detail.character }}</text>
    </view>
  </view>

  <!-- 寄养特有信息 -->
  <view class="info-section" wx:if="{{ detail._type === 'foster' }}">
    <view class="section-title">寄养信息</view>
    <view class="info-row" wx:if="{{ detail.startDate }}">
      <text class="info-label">寄养时段</text>
      <text class="info-val">{{ detail.startDate }} ~ {{ detail.endDate }}</text>
    </view>
    <view class="info-row" wx:if="{{ detail.days }}">
      <text class="info-label">天数</text>
      <text class="info-val">{{ detail.days }}天</text>
    </view>
    <view class="info-row" wx:if="{{ detail.budget }}">
      <text class="info-label">预算</text>
      <text class="info-val">¥{{ detail.budget }}</text>
    </view>
  </view>

  <!-- 送养特有信息 -->
  <view class="info-section" wx:if="{{ detail._type === 'adopt' }}">
    <view class="section-title">送养信息</view>
    <view class="info-row" wx:if="{{ detail.vaccinated }}">
      <text class="info-label">疫苗</text>
      <text class="info-val">{{ detail.vaccinated === 'yes' ? '已接种' : '未接种' }}</text>
    </view>
    <view class="info-row" wx:if="{{ detail.neutered }}">
      <text class="info-label">绝育</text>
      <text class="info-val">{{ detail.neutered === 'yes' ? '已绝育' : '未绝育' }}</text>
    </view>
    <view class="info-row" wx:if="{{ detail.reason }}">
      <text class="info-label">送养原因</text>
      <text class="info-val">{{ detail.reason }}</text>
    </view>
    <view class="info-row" wx:if="{{ detail.requirement }}">
      <text class="info-label">领养要求</text>
      <text class="info-val">{{ detail.requirement }}</text>
    </view>
  </view>

  <!-- 描述 -->
  <view class="info-section" wx:if="{{ detail.description }}">
    <view class="section-title">详细说明</view>
    <text class="desc-text">{{ detail.description }}</text>
  </view>

  <!-- 联系方式 -->
  <view class="info-section">
    <view class="section-title">联系方式</view>
    <view class="info-row">
      <text class="info-label">发布人</text>
      <text class="info-val">{{ detail.authorName || detail.contactName || '匿名' }}</text>
    </view>
    <view class="info-row" wx:if="{{ detail.location }}">
      <text class="info-label">所在地</text>
      <text class="info-val">{{ detail.location }}</text>
    </view>
  </view>

  <!-- 编辑区（仅发布者 + 编辑模式） -->
  <view class="info-section" wx:if="{{ isOwner && editing }}">
    <view class="section-title">修改信息</view>

    <!-- 寄养编辑 -->
    <block wx:if="{{ detail._type === 'foster' }}">
      <van-field label="寄养说明" type="textarea" placeholder="请详细描述寄养需求" value="{{ editDesc }}" bind:change="onEditDescChange" autosize="{{ { minHeight: 100 } }}"></van-field>
      <van-field label="预算价格" placeholder="如：50元/天" value="{{ editBudget }}" bind:change="onEditBudgetChange"></van-field>
      <van-field label="联系人" placeholder="您的称呼" value="{{ editContactName }}" bind:change="onEditContactNameChange"></van-field>
      <van-field label="手机号" placeholder="联系手机号" value="{{ editContactPhone }}" bind:change="onEditContactPhoneChange" type="number"></van-field>
      <van-field label="所在地区" placeholder="如：北京朝阳" value="{{ editLocation }}" bind:change="onEditLocationChange"></van-field>
    </block>

    <!-- 送养编辑 -->
    <block wx:if="{{ detail._type === 'adopt' }}">
      <van-field label="送养原因" type="textarea" placeholder="请说明送养原因" value="{{ editReason }}" bind:change="onEditReasonChange" autosize="{{ { minHeight: 100 } }}"></van-field>
      <van-field label="领养要求" type="textarea" placeholder="如：有养宠经验" value="{{ editRequirement }}" bind:change="onEditRequirementChange" autosize="{{ { minHeight: 80 } }}"></van-field>
      <van-field label="联系人" placeholder="您的称呼" value="{{ editContactName }}" bind:change="onEditContactNameChange"></van-field>
      <van-field label="手机号" placeholder="联系手机号" value="{{ editContactPhone }}" bind:change="onEditContactPhoneChange" type="number"></van-field>
      <van-field label="所在地区" placeholder="如：北京朝阳" value="{{ editLocation }}" bind:change="onEditLocationChange"></van-field>
    </block>

    <view class="edit-btn-row">
      <van-button round size="small" type="default" bindtap="cancelEdit" custom-style="flex:1;margin-right:16rpx;">取消</van-button>
      <van-button round size="small" type="primary" color="#FF9800" loading="{{ saving }}" loading-text="保存中" bindtap="saveEdit" custom-style="flex:1;">保存修改</van-button>
    </view>
  </view>

  <!-- 底部操作：非发布者 -->
  <view class="bottom-bar" wx:if="{{ !isOwner && detail.status === 'open' }}">
    <van-button round type="primary" color="linear-gradient(135deg, #FF9800, #FFB74D)" block loading="{{ applying }}" loading-text="提交中..." bindtap="onApply">
      {{ detail._type === 'adopt' ? '申请领养' : '接受寄养' }}
    </van-button>
  </view>

  <!-- 底部操作：发布者 -->
  <view class="bottom-bar owner-bar" wx:if="{{ isOwner && !editing }}">
    <van-button round plain size="small" icon="edit" type="primary" bindtap="startEdit" custom-style="flex:1;margin-right:12rpx;">编辑</van-button>
    <van-button round plain size="small" icon="delete-o" type="danger" bindtap="deletePost" custom-style="flex:1;">删除</van-button>
  </view>

</view>
