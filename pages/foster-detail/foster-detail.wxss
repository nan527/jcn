/* pages/foster-detail/foster-detail.wxss */
.detail-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

.img-swiper {
  width: 100%;
  height: 500rpx;
}

.swiper-img {
  width: 100%;
  height: 100%;
}

.img-placeholder {
  width: 100%;
  height: 360rpx;
  background: #eee;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 信息区 */
.info-section {
  background: #fff;
  margin: 20rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 28rpx 28rpx;
}

.info-row-main {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.pet-name {
  font-size: 38rpx;
  font-weight: 700;
  color: #333;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row {
  display: flex;
  padding: 10rpx 0;
}

.info-label {
  font-size: 26rpx;
  color: #999;
  width: 160rpx;
  flex-shrink: 0;
}

.info-val {
  font-size: 26rpx;
  color: #333;
  flex: 1;
  word-break: break-all;
}

.desc-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.8;
}

/* 底部操作 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 48rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
}

.owner-bar {
  display: flex;
  align-items: center;
}

/* 编辑区 */
.edit-btn-row {
  display: flex;
  margin-top: 28rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}
