/* pages/agency-services/agency-services.wxss */
.services-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-img {
  width: 240rpx;
  height: 240rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-top: 24rpx;
}

/* 分组 */
.group-section {
  margin: 24rpx 24rpx 0;
}

.group-header {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.group-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-left: 12rpx;
}

.group-count {
  font-size: 22rpx;
  color: #999;
  margin-left: 12rpx;
}

/* 服务卡片 */
.svc-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 28rpx 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.svc-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.svc-card-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  margin-right: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.svc-card-price {
  display: flex;
  align-items: baseline;
  flex-shrink: 0;
}

.price-symbol {
  font-size: 24rpx;
  color: #FF9800;
  font-weight: 700;
}

.price-value {
  font-size: 36rpx;
  font-weight: 800;
  color: #FF9800;
  margin: 0 2rpx;
}

.price-unit {
  font-size: 22rpx;
  color: #999;
}

.svc-card-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
  line-height: 1.5;
}

/* 服务图片缩略图 */
.svc-card-images {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.svc-thumb {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}

.svc-card-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f5f5;
}

.svc-card-actions {
  display: flex;
  align-items: center;
}

/* 底部添加按钮 */
.fab-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 48rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.06);
}
