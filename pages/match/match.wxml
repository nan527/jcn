<!-- pages/match/match.wxml -->
<view class="container">
  <view class="pet-selection">
    <picker bindchange="onPetChange" value="{{index}}" range="{{petList}}" range-key="name">
      <view class="picker">
        当前宠物: <text class="pet-name">{{selectedPet.name || '请先录入宠物档案'}}</text>
      </view>
    </picker>
  </view>

  <van-loading wx:if="{{loading}}" vertical>正在进行智能匹配...</van-loading>

  <scroll-view wx:else class="agency-list" scroll-y>
    <van-card
      wx:for="{{agencyList}}"
      wx:key="_id"
      num="剩余笼位: {{item.available_cages}}"
      price="{{item.price_per_day}}"
      title="{{item.name}}"
      thumb="{{item.photo || '/static/agency_default.png'}}"
    >
      <view slot="tags">
        <van-tag type="danger" plain>匹配度 {{item.match_score}}%</van-tag>
        <van-tag type="primary" plain style="margin-left: 10rpx;">{{item.address}}</van-tag>
      </view>
      <view slot="bottom">
        <text class="match-reason">💡 {{item.match_reason}}</text>
      </view>
      <view slot="footer">
        <van-button size="mini" type="info" bindtap="createOrder" data-id="{{item._id}}">立即预约</van-button>
      </view>
    </van-card>
  </scroll-view>
</view>
