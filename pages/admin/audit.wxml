<!-- pages/admin/audit.wxml -->
<view class="audit-page">
  <view class="page-title">机构入驻审核</view>

  <van-loading wx:if="{{ loading }}" vertical style="padding: 100rpx 0; text-align: center;">加载中...</van-loading>

  <view wx:if="{{ !loading && list.length === 0 }}" class="empty">暂无待审核/驳回机构</view>

  <view wx:for="{{ list }}" wx:key="userId" class="card">
    <view class="card-title-row">
      <text class="card-title">{{ item.profile.orgName || '未命名机构' }}</text>
      <text class="status {{ item.auditStatus === 'approved' ? 'status-ok' : (item.auditStatus === 'rejected' ? 'status-reject' : 'status-pending') }}">
        {{ item.auditStatus === 'pending' ? '待审核' : (item.auditStatus === 'approved' ? '已通过' : '已驳回') }}
      </text>
    </view>

    <view class="line"><text class="k">登录账号：</text><text class="v">{{ item.account }}</text></view>
    <view class="line"><text class="k">统一信用代码：</text><text class="v">{{ item.profile.creditCode || '-' }}</text></view>
    <view class="line"><text class="k">法人：</text><text class="v">{{ item.profile.legalName || '-' }} {{ item.profile.legalPhone || '' }}</text></view>
    <view class="line"><text class="k">地址：</text><text class="v">{{ item.profile.region || '' }} {{ item.profile.detailAddress || '' }}</text></view>
    <view class="line"><text class="k">经营类型：</text><text class="v">{{ item.profile.businessType || '-' }}</text></view>
    <view class="line"><text class="k">服务范围：</text><text class="v">{{ item.profile.serviceScope || '-' }}</text></view>

    <view class="image-row">
      <image wx:if="{{ item.profile.licenseImage }}" class="thumb" src="{{ item.profile.licenseImage }}" mode="aspectFill"></image>
      <image wx:if="{{ item.profile.storefrontImage }}" class="thumb" src="{{ item.profile.storefrontImage }}" mode="aspectFill"></image>
      <image wx:if="{{ item.profile.permitImage }}" class="thumb" src="{{ item.profile.permitImage }}" mode="aspectFill"></image>
    </view>

    <view class="actions">
      <van-button size="small" plain type="danger" data-user-id="{{ item.userId }}" data-profile-id="{{ item.profile._id }}" bindtap="reject">驳回</van-button>
      <van-button size="small" type="primary" color="#07c160" data-user-id="{{ item.userId }}" data-profile-id="{{ item.profile._id }}" bindtap="approve">通过</van-button>
    </view>
  </view>
</view>