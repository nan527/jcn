<!-- pages/post-detail/post-detail.wxml -->
<view class="detail-page">

  <!-- 加载中 -->
  <van-loading wx:if="{{ loading }}" vertical style="padding: 160rpx 0; text-align: center;">加载中...</van-loading>

  <block wx:if="{{ !loading && post }}">

    <!-- 作者信息 -->
    <view class="author-bar">
      <image class="author-avatar" src="{{ post.authorAvatar || '/static/missing-face.png' }}" mode="aspectFill"></image>
      <view class="author-info">
        <text class="author-name">{{ post.authorName || '匿名用户' }}</text>
        <text class="author-time">{{ post.createTime }}</text>
      </view>
    </view>

    <!-- 标题 -->
    <text class="post-title">{{ post.title }}</text>

    <!-- 话题标签 -->
    <view wx:if="{{ post.topics && post.topics.length > 0 }}" class="post-topics">
      <van-tag
        wx:for="{{ post.topics }}"
        wx:key="*this"
        plain
        color="#FF9800"
        style="margin-right: 12rpx;"
      >#{{ item }}</van-tag>
    </view>

    <!-- 正文 -->
    <text class="post-body">{{ post.content }}</text>

    <!-- 图片列表 -->
    <view wx:if="{{ post.images && post.images.length > 0 }}" class="post-images">
      <image
        wx:for="{{ post.images }}"
        wx:key="*this"
        class="post-img"
        src="{{ item }}"
        mode="widthFix"
        data-src="{{ item }}"
        bindtap="previewImage"
      ></image>
    </view>

    <!-- 操作栏 -->
    <view class="action-bar">
      <view class="action-item" bindtap="onLike">
        <van-icon name="good-job-o" size="40rpx" color="#FF9800"></van-icon>
        <text class="action-text">{{ post.likeCount || 0 }} 赞</text>
      </view>
      <view class="action-item">
        <van-icon name="comment-o" size="40rpx" color="#FF9800"></van-icon>
        <text class="action-text">{{ post.commentCount || 0 }} 评论</text>
      </view>
    </view>

    <!-- 分割线 -->
    <view class="divider">
      <text class="divider-text">评论区</text>
    </view>

    <!-- 评论列表 -->
    <view wx:if="{{ comments.length === 0 }}" class="no-comment">
      <text>暂无评论，快来抢沙发吧</text>
    </view>

    <view wx:for="{{ comments }}" wx:key="_id" class="comment-item">
      <image class="comment-avatar" src="{{ item.authorAvatar || '/static/missing-face.png' }}" mode="aspectFill"></image>
      <view class="comment-body">
        <text class="comment-author">{{ item.authorName || '匿名' }}</text>
        <text class="comment-content">{{ item.content }}</text>
      </view>
    </view>

  </block>

  <!-- 底部评论输入框 -->
  <view class="comment-bar" wx:if="{{ !loading && post }}">
    <van-field
      class="comment-input"
      placeholder="写评论…"
      value="{{ commentText }}"
      bind:change="onCommentInput"
      border="{{ false }}"
    ></van-field>
    <van-button
      size="small"
      round
      type="primary"
      color="#FF9800"
      loading="{{ sending }}"
      bindtap="sendComment"
    >发送</van-button>
  </view>

</view>
